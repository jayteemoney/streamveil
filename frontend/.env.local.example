# Chain the dApp talks to (Sepolia = 11155111). The Zama relayer SDK targets Sepolia.
NEXT_PUBLIC_CHAIN_ID=11155111

# Public RPC used for read-only calls (no wallet needed to browse streams).
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Optional address overrides. If unset, addresses are read from src/abi/deployment.json
# (which `npm run deploy:sepolia` regenerates after deployment).
# NEXT_PUBLIC_TOKEN_ADDRESS=0x...
# NEXT_PUBLIC_STREAMVEIL_ADDRESS=0x...
