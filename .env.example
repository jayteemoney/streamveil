# ---- Hardhat / contract deployment ----
# 12-word seed phrase for the DEPLOYER account (NEVER commit a real one).
# The FIRST account derived from this mnemonic (m/44'/60'/0'/0/0) is the deployer
# and must hold a little Sepolia ETH. Get test ETH from a faucet, e.g.:
#   https://sepoliafaucet.com  ·  https://www.alchemy.com/faucets/ethereum-sepolia
#   https://cloud.google.com/application/web3/faucet/ethereum/sepolia
MNEMONIC="test test test test test test test test test test test junk"

# Sepolia RPC endpoint. The public default works but can be rate-limited;
# a dedicated Infura/Alchemy key is recommended for reliable deploys + e2e testing:
#   SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/<your-key>"
#   SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/<your-key>"
SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# Etherscan key for contract verification (optional but nice for the submission)
ETHERSCAN_API_KEY=""

# Set to "true" to print a gas report when running tests
REPORT_GAS="false"
